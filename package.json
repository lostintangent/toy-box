{
  "name": "@lostintangent/toy-box",
  "version": "0.1.11",
  "description": "Your personal coding agent server",
  "bin": {
    "toy-box": "toy-box"
  },
  "files": [
    "toy-box"
  ],
  "os": [
    "darwin"
  ],
  "cpu": [
    "arm64"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "concurrently --kill-others --names \"app,ws\" --prefix-colors \"blue,green\" \"TERMINAL_WS_PORT=3101 vite dev --port 3100\" \"TERMINAL_WS_PORT=3101 bun run terminal-server/index.ts\"",
    "build": "vite build",
    "build:cli": "bun run build && bun build --compile --target=bun-darwin-arm64 ./cli/index.ts --outfile toy-box",
    "check": "tsc --noEmit",
    "format": "oxfmt",
    "lint": "oxlint",
    "prepare": "lefthook install"
  },
  "dependencies": {},
  "devDependencies": {
    "@github/copilot-sdk": "^1.0.0",
    "@radix-ui/react-alert-dialog": "^1.1.16",
    "@radix-ui/react-dialog": "^1.1.16",
    "@radix-ui/react-dropdown-menu": "^2.1.17",
    "@radix-ui/react-popover": "^1.1.16",
    "@radix-ui/react-scroll-area": "^1.2.11",
    "@radix-ui/react-select": "^2.3.0",
    "@radix-ui/react-separator": "^1.1.9",
    "@radix-ui/react-slot": "^1.2.5",
    "@radix-ui/react-tooltip": "^1.2.9",
    "@streamdown/code": "^1.1.1",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/devtools-vite": "^0.3.12",
    "@tanstack/react-devtools": "^0.7.11",
    "@tanstack/react-hotkeys": "^0.3.3",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-router": "^1.170.15",
    "@tanstack/react-router-devtools": "^1.167.0",
    "@tanstack/react-router-ssr-query": "^1.167.1",
    "@tanstack/react-start": "^1.168.25",
    "@tanstack/router-plugin": "^1.168.18",
    "@tanstack/zod-adapter": "^1.167.0",
    "@types/node": "^22.19.20",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-unicode11": "^0.9.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "bun-types": "^1.3.14",
    "citty": "^0.2.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "concurrently": "^9.2.1",
    "cron-parser": "^5.5.0",
    "db0": "^0.3.4",
    "jotai": "^2.20.0",
    "lefthook": "^2.1.9",
    "lucide-react": "^0.563.0",
    "nitro": "npm:nitro-nightly@latest",
    "open": "^11.0.0",
    "oxfmt": "^0.26.0",
    "oxlint": "^1.69.0",
    "radix-ui": "^1.5.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-resizable-panels": "^2.1.9",
    "shiki": "^3.23.0",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "use-stick-to-bottom": "^1.1.6",
    "vaul": "^1.1.2",
    "vite": "^7.3.5",
    "vite-tsconfig-paths": "^6.1.1",
    "zod": "^4.4.3"
  }
}
