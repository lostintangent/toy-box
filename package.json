{
  "name": "@lostintangent/toy-box",
  "version": "0.1.14",
  "description": "Your personal coding agent server",
  "bin": {
    "toy-box": "toy-box"
  },
  "files": [
    "toy-box"
  ],
  "os": [
    "darwin"
  ],
  "cpu": [
    "arm64"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "concurrently --kill-others --names \"app,ws\" --prefix-colors \"blue,green\" \"TERMINAL_WS_PORT=3101 vite dev --port 3100\" \"TERMINAL_WS_PORT=3101 bun run terminal-server/index.ts\"",
    "build": "vite build",
    "build:cli": "bun run build && bun build --compile --target=bun-darwin-arm64 ./cli/index.ts --outfile toy-box",
    "check": "tsc --noEmit",
    "format": "oxfmt",
    "lint": "oxlint",
    "prepare": "lefthook install"
  },
  "dependencies": {},
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@github/copilot-sdk": "^1.0.8",
    "@radix-ui/react-alert-dialog": "^1.1.21",
    "@radix-ui/react-dialog": "^1.1.21",
    "@radix-ui/react-dropdown-menu": "^2.1.22",
    "@radix-ui/react-popover": "^1.1.21",
    "@radix-ui/react-scroll-area": "^1.2.16",
    "@radix-ui/react-select": "^2.3.5",
    "@radix-ui/react-separator": "^1.1.13",
    "@radix-ui/react-slot": "^1.3.1",
    "@radix-ui/react-tooltip": "^1.2.14",
    "@rolldown/plugin-babel": "^0.2.3",
    "@streamdown/code": "^1.1.1",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.3",
    "@tanstack/ai": "^0.42.0",
    "@tanstack/ai-openai": "^0.17.1",
    "@tanstack/ai-react": "^0.18.1",
    "@tanstack/devtools-vite": "^0.7.2",
    "@tanstack/eslint-plugin-query": "5.101.2",
    "@tanstack/eslint-plugin-router": "1.162.0",
    "@tanstack/pacer": "^0.21.1",
    "@tanstack/react-devtools": "^0.10.9",
    "@tanstack/react-hotkeys": "^0.10.0",
    "@tanstack/react-pacer": "^0.22.1",
    "@tanstack/react-query": "^5.101.4",
    "@tanstack/react-router": "^1.170.18",
    "@tanstack/react-router-devtools": "^1.167.0",
    "@tanstack/react-router-ssr-query": "^1.167.1",
    "@tanstack/react-start": "^1.168.32",
    "@tanstack/react-store": "^0.11.0",
    "@tanstack/router-plugin": "^1.168.23",
    "@tanstack/store": "^0.11.0",
    "@tanstack/zod-adapter": "^1.167.0",
    "@types/babel__core": "^7.20.5",
    "@types/node": "^25.9.5",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.4",
    "@xmldom/xmldom": "^0.9.10",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-unicode11": "^0.9.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "bun-types": "^1.3.14",
    "citty": "^0.2.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
