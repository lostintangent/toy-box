    "oxfmt": "^0.60.0",
    "oxlint": "^1.75.0",
    "radix-ui": "^1.6.5",
    "react": "^19.2.8",
    "react-dom": "^19.2.8",
    "react-resizable-panels": "^2.1.9",
    "shiki": "^4.3.1",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.3",
    "tw-animate-css": "^1.4.0",
    "typescript": "^7.0.2",
    "use-stick-to-bottom": "^1.1.6",
    "vaul": "^1.1.2",
