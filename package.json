{
  "name": "@lostintangent/toy-box",
  "version": "0.1.12",
  "description": "Your personal coding agent server",
  "bin": {
    "toy-box": "toy-box"
  },
  "files": [
    "toy-box"
  ],
  "os": [
    "darwin"
  ],
  "cpu": [
    "arm64"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "concurrently --kill-others --names \"app,ws\" --prefix-colors \"blue,green\" \"TERMINAL_WS_PORT=3101 vite dev --port 3100\" \"TERMINAL_WS_PORT=3101 bun run terminal-server/index.ts\"",
    "build": "vite build",
    "build:cli": "bun run build && bun build --compile --target=bun-darwin-arm64 ./cli/index.ts --outfile toy-box",
    "check": "tsc --noEmit",
    "format": "oxfmt",
    "lint": "oxlint",
    "prepare": "lefthook install"
  },
  "dependencies": {},
  "devDependencies": {
    "@github/copilot-sdk": "^1.0.1",
    "@radix-ui/react-alert-dialog": "^1.1.17",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-dropdown-menu": "^2.1.18",
    "@radix-ui/react-popover": "^1.1.17",
    "@radix-ui/react-scroll-area": "^1.2.12",
    "@radix-ui/react-select": "^2.3.1",
    "@radix-ui/react-separator": "^1.1.10",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tooltip": "^1.2.10",
    "@streamdown/code": "^1.1.1",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.1",
    "@tanstack/devtools-vite": "^0.7.0",
    "@tanstack/react-devtools": "^0.10.5",
    "@tanstack/react-hotkeys": "^0.10.0",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-router": "^1.170.15",
    "@tanstack/react-router-devtools": "^1.167.0",
    "@tanstack/react-router-ssr-query": "^1.167.1",
    "@tanstack/react-start": "^1.168.25",
    "@tanstack/router-plugin": "^1.168.18",
    "@tanstack/zod-adapter": "^1.167.0",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-unicode11": "^0.9.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "bun-types": "^1.3.14",
    "citty": "^0.2.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "concurrently": "^10.0.3",
    "cron-parser": "^5.5.0",
    "db0": "^0.3.4",
    "jotai": "^2.20.1",
    "lefthook": "^2.1.9",
    "lucide-react": "^1.18.0",
    "nitro": "npm:nitro-nightly@^3.0.1-20260611-123640-7765bcb7",
    "open": "^11.0.0",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "radix-ui": "^1.6.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-resizable-panels": "^2.1.9",
    "shiki": "^4.2.0",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "use-stick-to-bottom": "^1.1.6",
    "vaul": "^1.1.2",
    "vite": "^8.0.16",
    "zod": "^4.4.3"
  },
  "//": "Feedback: this batch includes several major-version bumps (typescript 6, vite 8, @vitejs/plugin-react 6, shiki 4, lucide-react 1, @types/node 25, concurrently 10) — smoke-test build/dev before merging. Also note vite-tsconfig-paths was removed, so confirm tsconfig path aliases still resolve via vite.config.ts."
}
